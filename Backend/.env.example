# Exemplo de configuracao do backend AutoJuri.
# Copie para .env e preencha os valores reais.

# ── Servidor ──────────────────────────────────────────────────────────────────
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/contestacao-claude
N8N_EDICAO_WEBHOOK_URL=http://127.0.0.1:5678/webhook/editar-contestacao
N8N_WEBHOOK_PETICAO=http://127.0.0.1:5678/webhook/contestar-por-peticao
N8N_TIMEOUT_SECONDS=180
N8N_WEBHOOK_AUTH_TOKEN=

# ── Sessao ────────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=contestacao_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# ── PostgreSQL (via pooler Supabase) ─────────────────────────────────────────
DATABASE_URL=
DATABASE_HOST=aws-0-us-west-2.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.<project>
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT=10

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_EXTRACAO_MODEL=claude-sonnet-4-6
CLAUDE_VERIFICACAO_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_MS=120000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@seudominio.com
BACKEND_URL=http://autojuri_backend:8000
BACKEND_ADMIN_TOKEN=token_de_sessao_de_um_usuario_admin

# ── OCR (PR6 #3) ──────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_MAX_PAGES=15
OCR_DPI=300
OCR_LANG=por

# ── RAG Semantico / Embeddings (PR6 #4) ───────────────────────────────────────
# Escolha UM provider. Sem chave configurada o sistema usa TF-IDF automaticamente.
#
# Opcao A — Cohere (recomendado, $0.10/1M tokens, excelente PT-BR):
EMBEDDING_PROVIDER=cohere
COHERE_API_KEY=
#
# Opcao B — OpenAI (alternativa, $0.13/1M tokens):
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
#
# Nota: o schema pgvector usa vector(1024) para ambos os providers.
# Para ativar: instale a lib correspondente no container:
#   pip install "cohere>=5,<6"   OU   pip install "openai>=1"
# E rode o backfill para contestacoes existentes:
#   python docs/_dev/backfill_embeddings.py --limit 50 --dry-run
