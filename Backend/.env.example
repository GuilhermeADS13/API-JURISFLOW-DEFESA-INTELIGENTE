# Exemplo de configuracao do backend AutoJuri.
# Copie para .env e preencha os valores reais.

# ── Servidor ──────────────────────────────────────────────────────────────────
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://127.0.0.1:5678/webhook/contestacao-claude
N8N_EDICAO_WEBHOOK_URL=http://127.0.0.1:5678/webhook/editar-contestacao
N8N_WEBHOOK_PETICAO=http://127.0.0.1:5678/webhook/contestar-por-peticao
N8N_TIMEOUT_SECONDS=180
N8N_WEBHOOK_AUTH_TOKEN=
# PR8 P1.1 — retry com backoff exponencial (1s, 2s, 4s, ...) para tolerar
# cold-start ou reinicio do container n8n. Default: 3 tentativas, 1s base.
N8N_MAX_RETRIES=3
N8N_RETRY_BACKOFF_SECONDS=1.0

# ── Sessao ────────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=contestacao_session
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# ── PostgreSQL (via pooler Supabase) ─────────────────────────────────────────
DATABASE_URL=
DATABASE_HOST=aws-0-us-west-2.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.<project>
DATABASE_PASSWORD=sua_senha_aqui
DATABASE_SSLMODE=require
DATABASE_CONNECT_TIMEOUT=10

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_EXTRACAO_MODEL=claude-sonnet-4-6
CLAUDE_VERIFICACAO_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_MS=120000

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@seudominio.com
BACKEND_URL=http://autojuri_backend:8000
BACKEND_ADMIN_TOKEN=token_de_sessao_de_um_usuario_admin

# ── OCR (PR6 #3) ──────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_MAX_PAGES=15
OCR_DPI=300
OCR_LANG=por

# ── RAG Semantico / Embeddings (PR6 #4) ───────────────────────────────────────
# Provider default: 'local' (sentence-transformers, sem custo, roda no container).
# Modelo: paraphrase-multilingual-MiniLM-L12-v2 (118MB, 384 dims, PT-BR ok).
EMBEDDING_PROVIDER=local
# Override opcional do modelo local (qualquer modelo do HuggingFace compativel):
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
#
# Cache dos pesos do modelo (volume Docker hf_cache para nao baixar a cada rebuild):
HF_HOME=/app/hf_cache
TRANSFORMERS_OFFLINE=0
#
# Providers pagos (deprecated — exigem schema vector(1024) e migracao reversa):
# EMBEDDING_PROVIDER=cohere  + COHERE_API_KEY=...
# EMBEDDING_PROVIDER=openai  + OPENAI_API_KEY=sk-...
#
# Backfill de contestacoes antigas com embeddings:
#   python docs/_dev/backfill_embeddings.py --limit 50 --dry-run
