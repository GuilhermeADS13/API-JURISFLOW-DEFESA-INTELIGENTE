# ─────────────────────────────────────────────────────────────────────────────
# AutoJuri — Variaveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=6000
CLAUDE_TEMPERATURE=0.12
CLAUDE_TIMEOUT_MS=120000

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=

# ── PostgreSQL (Supabase Transaction Pooler) ──────────────────────────────────
DATABASE_URL=postgresql://postgres.xxx:SENHA@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_HOST=aws-0-us-west-2.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DATABASE_PASSWORD=SUA_SENHA_AQUI
DATABASE_SSLMODE=require

# ── Backend FastAPI ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
# Origens permitidas no CORS — em producao use o dominio do Vercel
FRONTEND_ORIGINS=https://autojuri.vercel.app,http://localhost:5173
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_HOURS=12
SESSION_CACHE_TTL_SECONDS=60
RATE_LIMIT_TRUST_FORWARDED=true
LOG_LEVEL=INFO

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_PORT=5678
# Em producao, coloque o dominio publico do n8n (Railway/Render)
N8N_WEBHOOK_URL=https://n8n.seudominio.com
# Webhook do workflow de edicao ciruurgica de .docx (Fase 1 do PLANO_IMPLEMENTACAO_2026-04-29)
N8N_EDICAO_WEBHOOK_URL=https://n8n.seudominio.com/webhook/editar-contestacao
N8N_SECURE_COOKIE=true
N8N_LOG_LEVEL=info

# ── Fase 2: feedback loop + exemplares ──────────────────────────────────────
# E-mails com acesso ao endpoint admin (separados por vírgula)
ADMIN_EMAILS=seu-email@escritorio.com

# Token Bearer que o n8n usa para chamar /api/admin/exemplares
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
BACKEND_ADMIN_TOKEN=

# URL do backend acessível de dentro da rede Docker (para o n8n)
BACKEND_URL=http://autojuri_backend:8000
