# ─────────────────────────────────────────────────────────────────────────────
# AutoJuri — Variaveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6
# Modelos por tarefa: extracao de dados e verificacao de citacoes usam Haiku
# (3-4x mais rapido/barato); so a geracao da peca usa Sonnet (CLAUDE_MODEL).
CLAUDE_EXTRACAO_MODEL=claude-haiku-4-5
CLAUDE_VERIFICACAO_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=6000
CLAUDE_TEMPERATURE=0.12
CLAUDE_TIMEOUT_MS=120000

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=
# JWT service_role (privilegio total). Recupere com:
#   npx supabase projects api-keys --project-ref <project-ref>
# Usar como fallback HTTPS REST quando o pooler PostgreSQL estiver bloqueado pela rede.
SUPABASE_SERVICE_ROLE_KEY=
# Timeout do Supabase Auth validation (validate_supabase_bearer_token)
SUPABASE_AUTH_TIMEOUT_SECONDS=8

# ── PostgreSQL (Supabase Transaction Pooler) ──────────────────────────────────
DATABASE_URL=postgresql://postgres.xxx:SENHA@aws-0-us-west-2.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_HOST=aws-0-us-west-2.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DATABASE_PASSWORD=SUA_SENHA_AQUI
DATABASE_SSLMODE=require
# Timeout para conexao com PostgreSQL (segundos). Aumente em redes lentas.
DATABASE_CONNECT_TIMEOUT=10

# ── Backend FastAPI ───────────────────────────────────────────────────────────
BACKEND_PORT=8000
# Origens permitidas no CORS — em producao use o dominio do Vercel
FRONTEND_ORIGINS=https://autojuri.vercel.app,http://localhost:5173
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_HOURS=12
SESSION_CACHE_TTL_SECONDS=60
RATE_LIMIT_TRUST_FORWARDED=true
LOG_LEVEL=INFO

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_PORT=5678
# Em producao, coloque o dominio publico do n8n (Railway/Render)
N8N_WEBHOOK_URL=https://n8n.seudominio.com
# Webhook do workflow de edicao ciruurgica de .docx (Fase 1 do PLANO_IMPLEMENTACAO_2026-04-29)
N8N_EDICAO_WEBHOOK_URL=https://n8n.seudominio.com/webhook/editar-contestacao
# Webhook do workflow de geracao a partir da peticao inicial (Guia Tecnico v2)
N8N_WEBHOOK_PETICAO=http://n8n:5678/webhook/contestar-por-peticao
# Modelo Claude usado pelo node Extrator do workflow contestar-por-peticao
CLAUDE_EXTRACAO_MODEL=claude-haiku-3-5
N8N_SECURE_COOKIE=true
N8N_LOG_LEVEL=info
# Timeout (s) para o backend aguardar resposta dos webhooks do n8n.
N8N_TIMEOUT_SECONDS=180
# Token Bearer opcional para autenticar chamadas backend -> webhooks n8n.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
N8N_WEBHOOK_AUTH_TOKEN=
# n8n Public API key (Settings -> API -> Create API Key). Para listar/ativar workflows
# via REST sem precisar autenticar OAuth. Header: X-N8N-API-KEY: <key>
N8N_API_KEY=

# ── Fase 2: feedback loop + exemplares ──────────────────────────────────────
# E-mails com acesso ao endpoint admin (separados por vírgula)
ADMIN_EMAILS=seu-email@escritorio.com

# Token Bearer que o n8n usa para chamar /api/admin/exemplares
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
BACKEND_ADMIN_TOKEN=

# URL do backend acessível de dentro da rede Docker (para o n8n)
BACKEND_URL=http://autojuri_backend:8000

# ── PR6 #3: OCR para PDFs digitalizados (Guia Tecnico v3 §2.7) ──────────────
# Tesseract local instalado no Dockerfile do backend (pacotes
# tesseract-ocr + tesseract-ocr-por + poppler-utils). Quando pypdf nao
# extrai texto (PDF imagem), faz fallback OCR.
OCR_ENABLED=true
# Maximo de paginas processadas pelo OCR (cada pagina ~5-10s; webhook n8n
# tem timeout 180s, manter conservador).
OCR_MAX_PAGES=15
# DPI da conversao PDF -> imagem. Tesseract recomenda 300.
OCR_DPI=300
# Idioma do Tesseract (precisa do pacote tesseract-ocr-<lang> instalado).
OCR_LANG=por

# ── Segurança & Operações (PR9 P2) ─────────────────────────────────────────
# n8n: bloqueio de acesso a variaveis de ambiente nos Code nodes.
# true = bloqueado (seguro em prod); false = permitido (conveniencia em dev)
N8N_BLOCK_ENV_ACCESS_IN_NODE=true

# Retry para chamadas do backend ao n8n (exponencial backoff).
N8N_MAX_RETRIES=3
N8N_RETRY_BACKOFF_SECONDS=1.0

# ── Backup do banco n8n (PostgreSQL em Producao) ─────────────────────────────
# Em producao, troque DB_TYPE=sqlite para DB_TYPE=postgresdb e configure:
# - DB_POSTGRESDB_HOST=postgres.seudominio.com
# - DB_POSTGRESDB_PORT=5432
# - DB_POSTGRESDB_DATABASE=n8n
# - DB_POSTGRESDB_USER=n8n_user
# - DB_POSTGRESDB_PASSWORD=...
# - DB_POSTGRESDB_SSL=true (se SSL obrigatorio)
#
# BACKUP MANUAL (SQLite local):
#   docker run --rm -v autojuri_n8n_data:/data -v $(pwd):/backup \
#     busybox tar czf /backup/n8n_backup_$(date +%Y%m%d_%H%M%S).tar.gz -C /data .
#
# RESTAURAR BACKUP (SQLite):
#   docker run --rm -v autojuri_n8n_data:/data -v $(pwd):/backup \
#     busybox tar xzf /backup/n8n_backup_YYYYMMDD_HHMMSS.tar.gz -C /data
